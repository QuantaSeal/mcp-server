{
  "$schema": "https://static.modelcontextprotocol.io/schemas/2025-12-11/server.schema.json",
  "name": "io.github.Lokeshwaranramu/quantaseal",
  "description": "Quantum-safe vault, encryption & compliance for AI agents. NIST FIPS 203/204 ML-KEM-768 + ML-DSA-65.",
  "version": "1.1.4",
  "repository": {
    "url": "https://github.com/QuantaSeal/quantaseal.git",
    "source": "github"
  },
  "homepage": "https://quantaseal.io/mcp",
  "license": "MIT",
  "icons": [
    {
      "src": "https://quantaseal.io/logo-icon.svg",
      "mimeType": "image/svg+xml"
    }
  ],
  "packages": [
    {
      "registryType": "npm",
      "identifier": "@quantaseal/mcp-server",
      "version": "1.1.4",
      "runtimeHint": "npx",
      "transport": {
        "type": "stdio"
      },
      "environmentVariables": [
        {
          "name": "QUANTASEAL_API_KEY",
          "description": "QuantaSeal API key (starts with qs_live_). Get one at https://app.quantaseal.io/settings/api-keys",
          "isRequired": true,
          "isSecret": true,
          "format": "string"
        },
        {
          "name": "QUANTASEAL_BASE_URL",
          "description": "Override API URL (optional, default: https://api.quantaseal.io)",
          "isRequired": false,
          "isSecret": false,
          "format": "string"
        }
      ]
    }
  ]
}
