{
  "name": "@quantaseal/mcp-server",
  "version": "1.0.0",
  "description": "QuantaSeal MCP Server - quantum-safe vault, encryption, and compliance tools for AI agents",
  "keywords": [
    "mcp",
    "model-context-protocol",
    "quantaseal",
    "quantum-safe",
    "post-quantum",
    "ML-KEM-768",
    "vault",
    "encryption"
  ],
  "homepage": "https://quantaseal.io",
  "repository": {
    "type": "git",
    "url": "https://github.com/quantaseal/quantaseal.git",
    "directory": "sdk/mcp"
  },
  "license": "MIT",
  "author": "QuantaSeal <sdk@quantaseal.io>",
  "type": "module",
  "main": "dist/server.js",
  "bin": {
